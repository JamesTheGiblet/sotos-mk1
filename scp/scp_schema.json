{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Semantic Capsule Protocol",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "protocol",
    "manifest",
    "semantic_context",
    "lifecycle",
    "signature"
  ],
  "properties": {
    "protocol": {
      "type": "object",
      "required": ["name", "version"]
    },
    "manifest": {
      "type": "object",
      "required": ["id", "name", "version", "type", "capabilities", "status"]
    },
    "semantic_context": {
      "type": "object",
      "required": ["regime", "entry_rules", "exit_rules", "risk_management"]
    },
    "lifecycle": {
      "type": "object",
      "required": ["status", "last_updated"],
      "properties": {
        "status": { "enum": ["hypothesis", "generated", "active_dry_run", "validated", "failed_validation", "archived"] }
      }
    },
    "signature": {
      "type": "object",
      "required": ["hash", "timestamp"]
    }
  }
}
